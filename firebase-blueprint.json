{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A productivity task",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the task"
        },
        "deadline": {
          "type": "string",
          "description": "Optional deadline for the task"
        },
        "completed": {
          "type": "boolean",
          "description": "Whether the task is completed"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore Timestamp of creation"
        }
      },
      "required": ["title", "completed", "createdAt"]
    }
  },
  "firestore": {
    "tasks": {
      "schema": "Task",
      "description": "Collection of tasks"
    }
  }
}
